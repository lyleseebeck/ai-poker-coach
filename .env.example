# Provider adapter to use for the coach endpoint.
COACH_PROVIDER=openrouter

# OpenRouter API key (required for coach requests).
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Comma-separated free models only. Every model must include :free.
COACH_OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free

# Optional: request timeout in ms (default: 25000)
COACH_REQUEST_TIMEOUT_MS=25000

# Optional headers for OpenRouter analytics/ranking
# COACH_SITE_URL=http://localhost:5173
# COACH_APP_NAME=AI Poker Coach
